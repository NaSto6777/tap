# Allow access to all uploaded files
Options -Indexes

# Grant access to everyone for image files
<IfModule mod_authz_core.c>
    # Apache 2.4
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    # Apache 2.2
    Order Allow,Deny
    Allow from all
</IfModule>

# Disable PHP execution for security
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# Set proper MIME types
<IfModule mod_mime.c>
    AddType image/jpeg jpg jpeg
    AddType image/png png
    AddType image/gif gif
    AddType image/webp webp
    AddType image/svg+xml svg
</IfModule>

